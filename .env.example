# Application
APP_NAME=AI Business Studio
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (Azure SQL / SQL Server)
DATABASE_URL=mssql+pyodbc://sa:YourStrong!Passw0rd@db:1433/aibusinessstudio?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AES-256 encryption key for API keys (32 bytes base64-encoded)
ENCRYPTION_KEY=change-me-32-byte-base64-encryption-key-here==

# Frontend
VITE_API_BASE_URL=http://localhost:8000
